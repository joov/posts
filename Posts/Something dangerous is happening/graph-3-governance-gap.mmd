%% Graph 3: The Governance Gap — Human Employee vs. AI Agent
%% Compares controls that exist for a human employee against those typically
%% absent for AI agents deployed with equivalent access.
%% Green = present, Red = absent, Amber = inconsistent.

flowchart TD
    title["🏛️ The Governance Gap
    AI agents act like employees — but without the controls we built for humans"]

    title --> HDR

    HDR["🔒 Controls applied to anyone with access to your systems"]

    HDR --> C1H & C1A
    HDR --> C2H & C2A
    HDR --> C3H & C3A
    HDR --> C4H & C4A
    HDR --> C5H & C5A
    HDR --> C6H & C6A

    subgraph Human["👤 Human Employee"]
        C1H["✅ 📋 Background check & vetting
        Standard practice"]
        C2H["✅ 📝 Defined access scope
        Role-based, least-privilege"]
        C3H["✅ 🪵 Audit trail
        HR records & system logs"]
        C4H["✅ ✋ Approval for high-stakes actions
        Manager sign-off, procurement"]
        C5H["✅ 🚪 Offboarding & revocation
        Formal process on exit"]
        C6H["✅ ⚖️ Accountability
        Legal contract, identifiable person"]
    end

    subgraph Agent["🤖 AI Agent"]
        C1A["❌ 📋 Background check & vetting
        Rarely performed"]
        C2A["⚠️ 📝 Defined access scope
        Often over-privileged or undefined"]
        C3A["⚠️ 🪵 Audit trail
        Inconsistent — rarely reviewed"]
        C4A["❌ ✋ Approval for high-stakes actions
        Autonomous — no human checkpoint"]
        C5A["❌ 🚪 Offboarding & revocation
        Tokens persist indefinitely"]
        C6A["❌ ⚖️ Accountability
        Unclear — no legal entity"]
    end

    Agent --> WARN["⚠️ This gap is being exploited now.
    88% of organisations reported an AI agent security incident in the past year.
    Sources: Bessemer Venture Partners · iEnable · beam.ai"]

    classDef titleStyle fill:#f5f5f5,stroke:#9e9e9e,stroke-width:2px,color:#212121,font-size:15px
    classDef header fill:#4e342e,stroke:#3e2723,color:#fff,font-weight:bold
    classDef present fill:#e8f5e9,stroke:#388e3c,color:#1b5e20,font-size:12px
    classDef absent fill:#ffebee,stroke:#c62828,color:#7f0000,font-size:12px
    classDef partial fill:#fff8e1,stroke:#f9a825,color:#4a3000,font-size:12px
    classDef warning fill:#fff3e0,stroke:#e65100,stroke-width:2px,color:#4a1a00,font-style:italic,font-size:12px

    class title titleStyle
    class HDR header
    class C1H,C2H,C3H,C4H,C5H,C6H present
    class C1A,C4A,C5A,C6A absent
    class C2A,C3A partial
    class WARN warning
